generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  listings  Listing[]
  favorites Favorite[]
  contacts  Contact[]
  newsletters Newsletter[]
}

model Listing {
  id          String   @id @default(cuid())
  name        String
  breed       String
  category    String
  subtype     String?
  age         String
  weight      String
  gender      String
  price       Int
  description String?
  milkYield   String?
  image       String
  images      String   @default("[]")
  location    String
  city        String?
  province    String?
  verified    Boolean  @default(false)
  featured    Boolean  @default(false)
  status      String   @default("active")
  sellerName  String
  phone       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  favorites   Favorite[]
}

model Favorite {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])

  @@unique([userId, listingId])
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
}
